{
  "name": "@back2u/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration src/test/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "openapi:dump": "tsx src/cli/dump-openapi.ts > openapi.json",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@back2u/shared-types": "workspace:*",
    "@sentry/node": "^8.47.0",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.4",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "inversify": "^8.2.2",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.2",
    "libsodium-wrappers": "^0.7.15",
    "mongoose": "^8.9.1",
    "pdfkit": "^0.15.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^4.0.1",
    "sharp": "0.32.6",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@back2u/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.8",
    "mongodb-memory-server": "^10.1.3",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
