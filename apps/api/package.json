{
  "name": "@back2u/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration src/test/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "openapi:dump": "tsx src/cli/dump-openapi.ts > openapi.json",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@back2u/shared-types": "workspace:*",
    "@sentry/node": "^10.67.0",
    "@xenova/transformers": "^2.17.2",
    "argon2": "^0.45.1",
    "bullmq": "^5.81.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "inversify": "^8.2.2",
    "ioredis": "5.11.1",
    "jsonwebtoken": "^9.0.3",
    "libsodium-wrappers": "^0.8.4",
    "mongoose": "^9.8.0",
    "pdfkit": "^0.19.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.18.0",
    "sharp": "0.35.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@back2u/config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/node": "^26.1.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.10",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
