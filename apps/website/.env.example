# Back2u marketing site — build-time env (all VITE_* are public/bundled).
# Copy to .env for local dev; set the same keys in the Vercel project settings.
VITE_API_URL=https://your-api.onrender.com          # Render API base URL
VITE_APP_URL=https://your-client-web.vercel.app     # the client-web app URL (CTAs link here)
VITE_MAPBOX_TOKEN=pk.your_public_mapbox_token       # public map embed
VITE_APP_STORE_URL=https://apps.apple.com/app/back2u
VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=app.back2u
VITE_CONTACT_EMAIL=hello@back2u.app
