# Copy to .env at the repo root only for local-dev convenience.
# Production: each app owns its own env via CI/secret manager.

# === API ===
NODE_ENV=development
PORT=4000
API_PUBLIC_URL=http://localhost:4000
# Public base URL of the user-facing web app (links in email/SMS/push). Set per env / white-label.
APP_PUBLIC_URL=http://localhost:5173

MONGO_URI=mongodb://localhost:27017/back2u
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-me-access-key-min-16-chars
JWT_REFRESH_SECRET=replace-me-refresh-key-min-16-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# === Resend (transactional email) ===
RESEND_API_KEY=
RESEND_FROM=Back2u <no-reply@back2u.app>

# === Cloudinary (image storage + PDF) ===
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === Anthropic ===
ANTHROPIC_API_KEY=

# === Mapbox ===
MAPBOX_TOKEN=

# === Twilio ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# === Hubtel mobile money ===
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_MERCHANT_ACCOUNT=

# === Expo push ===
EXPO_ACCESS_TOKEN=

# === Web push (VAPID) ===
# Generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@back2u.app

# === Vault encryption ===
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
VAULT_MASTER_KEY=

# === Observability ===
SENTRY_DSN=

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
# Optional regex for preview deploys, e.g. ^https://back2u-.*\.vercel\.app$
CORS_PREVIEW_REGEX=

# === Frontend (Vite) ===
VITE_API_URL=http://localhost:4000
VITE_MAPBOX_TOKEN=
VITE_APP_URL=http://localhost:5173

# === Marketing website (Vite) ===
# App store listing URLs (fall back to ${VITE_APP_URL}/download when unset)
VITE_APP_STORE_URL=
VITE_PLAY_STORE_URL=
# Public contact address shown in the website footer
VITE_CONTACT_EMAIL=hello@back2u.app

# === Mobile (Expo) ===
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_MAPBOX_TOKEN=
