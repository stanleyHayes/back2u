{
  "name": "back2u",
  "private": true,
  "version": "0.1.0",
  "description": "Smart Lost & Found Ecosystem",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "pnpm --filter @back2u/api test:unit",
    "test:integration": "pnpm --filter @back2u/api test:integration",
    "test:e2e": "pnpm --filter @back2u/client-web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\"",
    "prepare": "husky",
    "commitlint": "commitlint --edit",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.9.6",
    "turbo": "^2.10.6",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
